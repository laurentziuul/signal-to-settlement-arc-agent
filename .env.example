# Arc Testnet connection — no secrets required for read-only RPC
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Circle integration — optional, disabled by default
# Uncomment and fill in when activating Circle providers
# CIRCLE_AGENT_WALLET_ENABLED=true
# CIRCLE_AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress

# CIRCLE_GATEWAY_ENABLED=true
# CIRCLE_GATEWAY_API_KEY=your-gateway-api-key

# CIRCLE_CCTP_ENABLED=true
# CIRCLE_CCTP_DESTINATION_DOMAIN=0
# CIRCLE_CCTP_DESTINATION_ADDRESS=0xYourDestinationAddress

# X402_ENABLED=true
# X402_PAY_FACILITATOR_URL=https://your-facilitator-url
# X402_RESOURCE_URL=https://your-resource-url
